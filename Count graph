<style>
  #mwStatsSection{
    --mw-card-light: #EEF3FB;
    --mw-card-mint: #DCE7FA;
    --mw-card-primary: #0540F2;
    --mw-card-primary-2: #2C63FF;
    --mw-text: #0F172A;
    --mw-blue: #0540F2;
    --mw-blue-2: #4E7CFF;
    --mw-white: #ffffff;
    --mw-radius: 30px;
    --mw-shadow: 0 20px 40px rgba(19, 48, 120, .10);
    width: 100%;
    padding: 24px 0;
    background: transparent;
    font-family: 'Pretendard', 'Noto Sans KR', sans-serif;
  }

  #mwStatsSection *{
    box-sizing: border-box;
    word-break: keep-all;
  }

  #mwStatsSection .mw-stats-grid{
    width: min(100%, 1320px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 1fr 1fr 1fr;
    grid-template-areas:
      "card1 card1 card2 card2"
      "card3 card3 card4 card4";
    gap: 18px;
  }

  #mwStatsSection .mw-stat-card{
    position: relative;
    min-height: 300px;
    border-radius: var(--mw-radius);
    overflow: hidden;
    box-shadow: var(--mw-shadow);
    transform: translateY(24px);
    opacity: 0;
    transition: transform .8s ease, opacity .8s ease;
  }

  #mwStatsSection .mw-stat-card.is-visible{
    transform: translateY(0);
    opacity: 1;
  }

  #mwStatsSection .mw-card-inner{
    position: relative;
    height: 100%;
    padding: 40px 44px;
    z-index: 2;
  }

  #mwStatsSection .mw-card-light{
    background: var(--mw-card-light);
  }

  #mwStatsSection .mw-card-mint{
    background: linear-gradient(180deg, #E4ECFC 0%, #D9E5FB 100%);
  }

  #mwStatsSection .mw-card-primary{
    background: linear-gradient(135deg, var(--mw-card-primary) 0%, var(--mw-card-primary-2) 100%);
    border-radius: var(--mw-radius);
    overflow: hidden;
  }

  #mwStatsSection .mw-card-light:nth-child(1){ grid-area: card1; }
  #mwStatsSection .mw-card-graph{ grid-area: card2; }
  #mwStatsSection .mw-card-wide{ grid-area: card3; min-height: 370px; }
  #mwStatsSection .mw-card-light:nth-child(4){ grid-area: card4; }

  #mwStatsSection .mw-stat-label{
    margin: 0 0 22px;
    font-size: 16px;
    line-height: 1.4;
    font-weight: 700;
    color: var(--mw-text);
    letter-spacing: -0.02em;
  }

  #mwStatsSection .mw-stat-label.mw-white,
  #mwStatsSection .mw-white{
    color: var(--mw-white);
  }

  #mwStatsSection .mw-stat-number-row{
    display: flex;
    align-items: flex-end;
    gap: 10px;
    flex-wrap: wrap;
    position: relative;
    z-index: 3;
  }

  #mwStatsSection .mw-stat-number{
    display: inline-block;
    font-size: clamp(52px, 5vw, 84px);
    line-height: .95;
    font-weight: 500;
    letter-spacing: -0.05em;
    color: var(--mw-blue);
  }

  #mwStatsSection .mw-stat-unit{
    padding-bottom: 10px;
    font-size: clamp(20px, 1.5vw, 28px);
    font-weight: 700;
    line-height: 1;
    color: var(--mw-blue);
    letter-spacing: -0.03em;
  }

  #mwStatsSection .mw-stat-note{
    position: absolute;
    left: 44px;
    bottom: 30px;
    z-index: 4;
    margin: 0;
    color: rgba(15, 23, 42, .52);
    font-size: 13px;
    line-height: 1.35;
    font-weight: 600;
    letter-spacing: 0;
  }

  #mwStatsSection .mw-stat-note.mw-white{
    color: rgba(255, 255, 255, .72);
  }

  /* ===== 파란 그래프 카드 안 텍스트 흰색 강제 ===== */
  #mwStatsSection .mw-card-primary .mw-stat-label,
  #mwStatsSection .mw-card-primary .mw-stat-number,
  #mwStatsSection .mw-card-primary .mw-stat-unit{
    color: #ffffff !important;
  }

  #mwStatsSection .mw-card-primary .mw-stat-number{
    text-shadow: 0 2px 12px rgba(0,0,0,.08);
  }

  /* 카드 장식 */
  #mwStatsSection .mw-card-deco{
    position: absolute;
    inset: auto 0 0 auto;
    pointer-events: none;
  }

  #mwStatsSection .mw-stat-icon{
    right: 24px;
    bottom: 18px;
    width: clamp(118px, 15vw, 190px);
    aspect-ratio: 1 / 1;
    z-index: 1;
  }

  #mwStatsSection .mw-stat-icon img{
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transform-origin: center;
    filter: drop-shadow(0 16px 22px rgba(5, 64, 242, .12));
  }

  #mwStatsSection .mw-icon-calendar{
    width: clamp(128px, 16vw, 206px);
    animation: mwCalendarBreath 3.8s ease-in-out infinite;
  }

  #mwStatsSection .mw-icon-calendar img{
    opacity: .96;
  }

  #mwStatsSection .mw-icon-day{
    position: absolute;
    left: 16%;
    right: 16%;
    top: 52%;
    transform: translateY(-50%);
    color: var(--mw-blue-2);
    font-size: clamp(20px, 2.7vw, 44px);
    line-height: 1;
    font-weight: 700;
    text-align: center;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }

  #mwStatsSection .mw-icon-implant{
    right: 26px;
    bottom: 2px;
    width: clamp(140px, 19vw, 250px);
    animation: mwImplantFloat 4.2s ease-in-out infinite;
  }

  #mwStatsSection .mw-icon-implant img{
    animation: mwImplantTurn 4.2s ease-in-out infinite;
  }

  #mwStatsSection .mw-icon-arrow{
    right: 22px;
    bottom: 10px;
    width: clamp(150px, 22vw, 286px);
    overflow: visible;
  }

  #mwStatsSection .mw-icon-arrow::before,
  #mwStatsSection .mw-icon-arrow::after{
    content: "";
    position: absolute;
    left: 50%;
    bottom: 8%;
    width: 52%;
    height: 12%;
    background: rgba(78, 124, 255, .20);
    transform: translateX(-50%);
    animation: mwArrowRiseLine 1.8s ease-out infinite;
  }

  #mwStatsSection .mw-icon-arrow::after{
    width: 42%;
    animation-delay: .42s;
  }

  #mwStatsSection .mw-icon-arrow img{
    animation: mwArrowLift 1.8s cubic-bezier(.22,.61,.36,1) infinite;
  }

  #mwStatsSection .mw-icon-face{
    right: 30px;
    bottom: 16px;
    width: clamp(150px, 21vw, 282px);
    animation: mwFaceFloat 4.8s ease-in-out infinite;
  }

  #mwStatsSection .mw-icon-face img{
    animation: mwFaceSway 4.8s ease-in-out infinite;
  }

  @keyframes mwCalendarBreath{
    0%, 100%{ transform: translateY(0) scale(1); }
    50%{ transform: translateY(-6px) scale(1.015); }
  }

  @keyframes mwImplantFloat{
    0%, 100%{ transform: translateY(-4px); }
    50%{ transform: translateY(18px); }
  }

  @keyframes mwImplantTurn{
    0%, 100%{ transform: rotate(-5deg); }
    50%{ transform: rotate(8deg); }
  }

  @keyframes mwArrowLift{
    0%{ transform: translateY(16px); opacity: .64; }
    44%{ transform: translateY(-8px); opacity: 1; }
    100%{ transform: translateY(-20px); opacity: .78; }
  }

  @keyframes mwArrowRiseLine{
    0%{ transform: translate(-50%, 22px) scaleX(.8); opacity: 0; }
    35%{ opacity: .62; }
    100%{ transform: translate(-50%, -70px) scaleX(1); opacity: 0; }
  }

  @keyframes mwFaceFloat{
    0%, 100%{ transform: translate3d(0, 0, 0); }
    35%{ transform: translate3d(-5px, -14px, 0); }
    70%{ transform: translate3d(6px, -7px, 0); }
  }

  @keyframes mwFaceSway{
    0%, 100%{ transform: rotate(0deg); }
    50%{ transform: rotate(2.5deg); }
  }

  /* 반응형 */
  @media (max-width: 1100px){
    #mwStatsSection .mw-stats-grid{
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "card1 card2"
        "card3 card4";
    }

  }

  @media (max-width: 767px){
    #mwStatsSection{
      padding: 12px 0;
    }

    #mwStatsSection .mw-stats-grid{
      grid-template-columns: 1fr;
      grid-template-areas:
        "card1"
        "card2"
        "card3"
        "card4";
      gap: 14px;
    }

    #mwStatsSection .mw-stat-card,
    #mwStatsSection .mw-card-wide{
      min-height: auto;
    }

    #mwStatsSection .mw-card-inner{
      padding: 28px 24px;
    }

    #mwStatsSection .mw-stat-label{
      margin-bottom: 16px;
      font-size: 15px;
    }

    #mwStatsSection .mw-stat-number{
      font-size: clamp(44px, 13vw, 62px);
    }

    #mwStatsSection .mw-stat-unit{
      font-size: 18px;
      padding-bottom: 6px;
    }

    #mwStatsSection .mw-stat-note{
      position: relative;
      left: auto;
      bottom: auto;
      margin-top: 18px;
      font-size: 12px;
    }

    #mwStatsSection .mw-stat-icon{
      position: relative;
      right: auto;
      bottom: auto;
      width: min(48vw, 190px);
      margin: 18px 0 0 auto;
    }

    #mwStatsSection .mw-icon-implant,
    #mwStatsSection .mw-icon-arrow,
    #mwStatsSection .mw-icon-face{
      width: min(56vw, 220px);
    }

}

@media (prefers-reduced-motion: reduce){
  #mwStatsSection .mw-stat-card,
  #mwStatsSection .mw-stat-icon,
  #mwStatsSection .mw-stat-icon img,
  #mwStatsSection .mw-icon-arrow::before,
  #mwStatsSection .mw-icon-arrow::after{
    animation: none !important;
    transition: none !important;
  }
}
</style>

<script>
(function(){
  const section = document.getElementById('mwStatsSection');
  if(!section) return;

  const dayCounter = section.querySelector('.mw-stat-number[data-start-date]');
  const dayLabel = section.querySelector('#clinicDays');

  function getDaysFrom(startDateValue){
    const parts = String(startDateValue || '').split('-').map(Number);
    if(parts.length !== 3 || parts.some(Number.isNaN)) return 0;

    const start = new Date(parts[0], parts[1] - 1, parts[2]);
    const now = new Date();
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const msPerDay = 1000 * 60 * 60 * 24;

    return Math.max(0, Math.floor((today - start) / msPerDay) + 1);
  }

  if(dayCounter){
    const dayCount = getDaysFrom(dayCounter.dataset.startDate);
    dayCounter.dataset.target = String(dayCount);

    if(dayLabel){
      dayLabel.textContent = dayCount.toLocaleString('ko-KR');
    }
  }

  const counters = section.querySelectorAll('.mw-stat-number[data-target]');
  const revealCards = section.querySelectorAll('.mw-reveal');

  function formatNumber(num){
    return Number(num).toLocaleString('ko-KR');
  }

  function animateCounter(el){
    if(el.dataset.done === 'true') return;
    el.dataset.done = 'true';

    const target = parseInt(el.dataset.target || '0', 10);
    const suffix = el.dataset.suffix || '';
    const duration = target >= 100000 ? 2200 : 1600;

    let startTime = null;

    function step(timestamp){
      if(!startTime) startTime = timestamp;
      const progress = Math.min((timestamp - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.floor(target * eased);

      el.textContent = formatNumber(current) + suffix;

      if(progress < 1){
        requestAnimationFrame(step);
      }else{
        el.textContent = formatNumber(target) + suffix;
      }
    }

    requestAnimationFrame(step);
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if(entry.isIntersecting){
        const target = entry.target;

        if(target.classList.contains('mw-reveal')){
          target.classList.add('is-visible');
        }

        if(target === section){
          counters.forEach((counter, idx) => {
            setTimeout(() => animateCounter(counter), idx * 120);
          });

          observer.unobserve(section);
        }
      }
    });
  }, {
    threshold: 0.25
  });

  revealCards.forEach(card => observer.observe(card));
  observer.observe(section);
})();
// ===== 개원일 캘린더 숫자 연동 =====
(function(){
  const counter = document.querySelector('[data-start-date]');
  const label = document.getElementById('clinicDays');

  if(!counter || !label) return;

  function sync(){
    const num = counter.textContent.replace(/[^\d]/g,'');
    label.textContent = Number(num || 0).toLocaleString('ko-KR');
    requestAnimationFrame(sync);
  }

  sync();
})();
</script>
