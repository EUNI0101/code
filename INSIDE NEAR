</style>

<script>
(function(){
  function initMwInsidePoswel(){
    const wrap = document.querySelector('#mwInsidePoswel');
    if(!wrap) return;

    const buttons = Array.from(wrap.querySelectorAll('.mw-cate-btn'));
    const titleEl = wrap.querySelector('#mwInsideCurrentTitle');
    const descEl = wrap.querySelector('#mwInsideCurrentDesc');
    const imageEl = wrap.querySelector('#mwInsideMainImage');
    const labelEl = wrap.querySelector('#mwInsideImageLabel');
    const counterEl = wrap.querySelector('#mwInsideCounter');
    const mediaEl = wrap.querySelector('.mw-inside-media');
    const prevBtn = wrap.querySelector('.mw-arrow.prev');
    const nextBtn = wrap.querySelector('.mw-arrow.next');
    const linkBtn = wrap.querySelector('.mw-copy-btn');

    if(!buttons.length || !linkBtn) return;

    let currentIndex = 0;

    function updateSlide(index){
      const item = buttons[index];
      if(!item) return;

      const title = item.dataset.title || '';
      const desc = item.dataset.desc || '';
      const img = item.dataset.img || '';
      const link = item.dataset.link || '#';

      buttons.forEach(btn => btn.classList.remove('is-active'));
      item.classList.add('is-active');

      currentIndex = index;

      if(titleEl) titleEl.textContent = title;
      if(descEl) descEl.textContent = desc;
      if(labelEl) labelEl.textContent = title;
      if(imageEl) imageEl.src = img;

      /* ✅ 핵심: 더 알아보기 버튼 링크를 직접 변경 */
      linkBtn.href = link;

      if(counterEl){
        counterEl.textContent =
          String(index + 1).padStart(2, '0') + ' / ' +
          String(buttons.length).padStart(2, '0');
      }

      if(mediaEl){
        mediaEl.classList.add('is-changing');
        setTimeout(() => {
          mediaEl.classList.remove('is-changing');
        }, 360);
      }
    }

    buttons.forEach((btn, idx) => {
      btn.addEventListener('click', function(e){
        e.preventDefault();
        updateSlide(idx);

        const link = btn.dataset.link;
        if(link){
          window.location.href = link;
        }
      });
    });

    if(prevBtn){
      prevBtn.addEventListener('click', function(){
        updateSlide((currentIndex - 1 + buttons.length) % buttons.length);
      });
    }

    if(nextBtn){
      nextBtn.addEventListener('click', function(){
        updateSlide((currentIndex + 1) % buttons.length);
      });
    }

    updateSlide(0);
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', initMwInsidePoswel);
  }else{
    initMwInsidePoswel();
  }
})();
</script>
