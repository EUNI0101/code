<section class="ok-chain" id="ok-chain">
  <div class="ok-chain__inner">
    <div class="ok-chain__heading">
      <h2>
        당신의 매일이 오케이가 되도록<br>
        <strong>OK 체인지 시스템</strong>
      </h2>
      <p>
        환자의 상태와 회복 목표에 맞춰 단계별로 맞춤 진행되며<br>
        단순한 통증 완화를 넘어 건강한 일상으로의 CHANGE 여정을 함께합니다.
      </p>
      <p>통증부터 근육 케어까지, 최적의 치료를 위한 오케이의 약속입니다.</p>
    </div>

    <div class="ok-chain__stage" aria-live="polite">
      <article class="ok-chain__card">
        <div class="ok-chain__image">
          <img src="https://images.unsplash.com/photo-1581093458791-9f3c3900df4b?auto=format&fit=crop&w=900&q=80" alt="">
        </div>
        <div class="ok-chain__body">
          <h3><span>3D 데이터 확보</span> <em>3D Digital Data</em></h3>
          <p>초기 통증과 염증을 완화하여 손상된 조직의 회복을 돕습니다.</p>
        </div>
      </article>
    </div>

    <div class="ok-chain__timeline">
      <div class="ok-chain__line" aria-hidden="true"></div>
      <div class="ok-chain__dotline" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="ok-chain__steps" role="tablist" aria-label="OK 체인지 시스템 단계">
        <button class="ok-chain__step is-active" type="button" role="tab" aria-selected="true" data-step="0">
          <span class="ok-chain__num">01</span>
          <span class="ok-chain__label">3D 데이터 확보</span>
        </button>
        <button class="ok-chain__step" type="button" role="tab" aria-selected="false" data-step="1">
          <span class="ok-chain__num">02</span>
          <span class="ok-chain__label">디지털 모의시술</span>
        </button>
        <button class="ok-chain__step" type="button" role="tab" aria-selected="false" data-step="2">
          <span class="ok-chain__num">03</span>
          <span class="ok-chain__label">네비게이션<br>수술 가이드 제작</span>
        </button>
        <button class="ok-chain__step" type="button" role="tab" aria-selected="false" data-step="3">
          <span class="ok-chain__num">04</span>
          <span class="ok-chain__label">시술완료</span>
        </button>
        <button class="ok-chain__step" type="button" role="tab" aria-selected="false" data-step="4">
          <span class="ok-chain__num">05</span>
          <span class="ok-chain__label">사후관리</span>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .ok-chain {
    --ok-blue: #3d86ff;
    --ok-blue-soft: rgba(61, 134, 255, .22);
    --ok-bg: #e9eff8;
    --ok-muted: rgba(15, 23, 42, .28);
    --active-x: 0px;
    overflow: hidden;
    background: var(--ok-bg);
    color: #111827;
    font-family: Pretendard, "Noto Sans KR", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .ok-chain__inner {
    position: relative;
    max-width: 1920px;
    min-height: 900px;
    margin: 0 auto;
    padding: 62px 88px 86px;
  }

  .ok-chain__inner::before {
    content: "";
    position: absolute;
    top: 0;
    left: 54px;
    width: 1px;
    height: 330px;
    background: rgba(17, 24, 39, .45);
  }

  .ok-chain__heading {
    text-align: center;
  }

  .ok-chain__heading h2 {
    margin: 0;
    font-size: clamp(38px, 3.05vw, 58px);
    font-weight: 800;
    line-height: 1.45;
    letter-spacing: 0;
  }

  .ok-chain__heading h2 strong {
    display: inline-block;
    margin-top: 8px;
    font: inherit;
  }

  .ok-chain__heading p {
    margin: 34px 0 0;
    color: #1f2937;
    font-size: clamp(18px, 1.25vw, 24px);
    font-weight: 500;
    line-height: 1.75;
    letter-spacing: 0;
  }

  .ok-chain__heading p + p {
    margin-top: 30px;
  }

  .ok-chain__stage {
    position: relative;
    height: 430px;
    margin-top: 54px;
  }

  .ok-chain__card {
    position: absolute;
    left: var(--active-x);
    bottom: 72px;
    width: min(384px, 24vw);
    min-width: 320px;
    overflow: hidden;
    border-radius: 26px;
    background: #fff;
    box-shadow: 0 18px 36px rgba(79, 97, 129, .12);
    opacity: 1;
    transform: translateX(-50%);
    transition: left .55s ease, opacity .25s ease, transform .55s ease;
  }

  .ok-chain__card.is-changing {
    opacity: .35;
    transform: translateX(-50%) translateY(8px);
  }

  .ok-chain__image {
    aspect-ratio: 1.68 / 1;
    overflow: hidden;
    background: #dbe5f1;
  }

  .ok-chain__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ok-chain__body {
    min-height: 156px;
    padding: 27px 24px 32px;
  }

  .ok-chain__body h3 {
    margin: 0;
    font-size: clamp(20px, 1.25vw, 25px);
    font-weight: 800;
    line-height: 1.28;
    letter-spacing: 0;
  }

  .ok-chain__body h3 em {
    color: rgba(17, 24, 39, .28);
    font-style: normal;
    font-weight: 800;
  }

  .ok-chain__body p {
    margin: 22px 0 0;
    color: #586174;
    font-size: clamp(16px, 1vw, 19px);
    font-weight: 700;
    line-height: 1.9;
    letter-spacing: 0;
  }

  .ok-chain__timeline {
    position: relative;
    margin: 0 auto;
    padding-top: 26px;
  }

  .ok-chain__line {
    position: absolute;
    top: 0;
    left: 42px;
    right: 42px;
    height: 20px;
    border-radius: 999px;
    background: rgba(126, 148, 178, .42);
  }

  .ok-chain__dotline {
    position: absolute;
    top: -12px;
    left: 42px;
    right: 42px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    pointer-events: none;
  }

  .ok-chain__dotline span {
    justify-self: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: var(--ok-blue-soft);
  }

  .ok-chain__dotline span::after {
    content: "";
    display: block;
    width: 16px;
    height: 16px;
    margin: 14px auto;
    border-radius: 999px;
    background: var(--ok-blue);
  }

  .ok-chain__steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0;
    z-index: 1;
  }

  .ok-chain__step {
    display: grid;
    justify-items: center;
    align-content: start;
    min-height: 150px;
    padding: 30px 8px 0;
    border: 0;
    background: transparent;
    color: var(--ok-muted);
    font-family: inherit;
    cursor: pointer;
  }

  .ok-chain__num {
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    border: 11px solid rgba(255, 255, 255, .56);
    border-radius: 999px;
    background: #fff;
    color: rgba(17, 24, 39, .3);
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
    box-sizing: content-box;
    transition: background .25s ease, border-color .25s ease, color .25s ease;
  }

  .ok-chain__label {
    display: block;
    margin-top: 17px;
    font-size: clamp(18px, 1.32vw, 26px);
    font-weight: 800;
    line-height: 1.35;
    letter-spacing: 0;
    transition: color .25s ease;
  }

  .ok-chain__step.is-active {
    color: #05070b;
  }

  .ok-chain__step.is-active .ok-chain__num {
    border-color: var(--ok-blue-soft);
    background: var(--ok-blue);
    color: #fff;
  }

  @media (max-width: 1024px) {
    .ok-chain__inner {
      min-height: auto;
      padding: 54px 28px 64px;
    }

    .ok-chain__inner::before {
      left: 20px;
      height: 240px;
    }

    .ok-chain__heading p {
      margin-top: 24px;
    }

    .ok-chain__stage {
      height: 380px;
    }

    .ok-chain__card {
      width: 330px;
      min-width: 0;
      bottom: 56px;
    }

    .ok-chain__line,
    .ok-chain__dotline {
      left: 30px;
      right: 30px;
    }
  }

  @media (max-width: 767px) {
    .ok-chain__inner {
      padding: 44px 18px 46px;
    }

    .ok-chain__heading h2 {
      font-size: 30px;
      line-height: 1.36;
    }

    .ok-chain__heading p {
      font-size: 16px;
      line-height: 1.7;
    }

    .ok-chain__heading p br {
      display: none;
    }

    .ok-chain__stage {
      height: auto;
      margin-top: 36px;
    }

    .ok-chain__card {
      position: relative;
      left: auto;
      bottom: auto;
      width: 100%;
      max-width: 390px;
      margin: 0 auto;
      transform: none;
    }

    .ok-chain__card.is-changing {
      transform: translateY(8px);
    }

    .ok-chain__timeline {
      margin-top: 44px;
      overflow-x: auto;
      padding: 22px 0 8px;
    }

    .ok-chain__line {
      left: 44px;
      right: auto;
      width: 690px;
      height: 14px;
    }

    .ok-chain__dotline {
      left: 44px;
      right: auto;
      width: 690px;
      top: -5px;
    }

    .ok-chain__dotline span {
      width: 34px;
      height: 34px;
    }

    .ok-chain__dotline span::after {
      width: 12px;
      height: 12px;
      margin-top: 11px;
    }

    .ok-chain__steps {
      width: 780px;
    }

    .ok-chain__step {
      min-height: 128px;
      padding-top: 26px;
    }

    .ok-chain__num {
      width: 46px;
      height: 46px;
      border-width: 9px;
      font-size: 18px;
    }

    .ok-chain__label {
      font-size: 17px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.querySelector('#ok-chain');
    if (!section) return;

    const steps = [
      {
        title: '3D 데이터 확보',
        english: '3D Digital Data',
        text: '초기 통증과 염증을 완화하여 손상된 조직의 회복을 돕습니다.',
        image: 'https://images.unsplash.com/photo-1581093458791-9f3c3900df4b?auto=format&fit=crop&w=900&q=80'
      },
      {
        title: '디지털 모의시술',
        english: 'Digital Simulation',
        text: '정밀 데이터를 바탕으로 환자에게 맞는 치료 계획을 시뮬레이션합니다.',
        image: 'https://images.unsplash.com/photo-1584982751601-97dcc096659c?auto=format&fit=crop&w=900&q=80'
      },
      {
        title: '네비게이션',
        english: 'Surgical Guide',
        text: '계획된 위치와 각도를 기준으로 수술 가이드를 제작합니다.',
        image: 'https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&w=900&q=80'
      },
      {
        title: '시술완료',
        english: 'Treatment Complete',
        text: '정밀한 가이드를 활용해 부담을 줄이고 안정적인 시술을 진행합니다.',
        image: 'https://images.unsplash.com/photo-1606811971618-4486d14f3f99?auto=format&fit=crop&w=900&q=80'
      },
      {
        title: '사후관리',
        english: 'After Care',
        text: '시술 후 회복 상태를 확인하며 오래 유지될 수 있도록 관리합니다.',
        image: 'https://images.unsplash.com/photo-1631217868264-e5b90bb7e133?auto=format&fit=crop&w=900&q=80'
      }
    ];

    const card = section.querySelector('.ok-chain__card');
    const cardImage = section.querySelector('.ok-chain__image img');
    const cardTitle = section.querySelector('.ok-chain__body h3');
    const cardText = section.querySelector('.ok-chain__body p');
    const stepButtons = Array.from(section.querySelectorAll('.ok-chain__step'));

    function updateCardPosition(index) {
      const currentButton = stepButtons[index];
      const stage = section.querySelector('.ok-chain__stage');
      const buttonRect = currentButton.getBoundingClientRect();
      const stageRect = stage.getBoundingClientRect();
      const center = buttonRect.left + (buttonRect.width / 2) - stageRect.left;
      const cardHalf = card.offsetWidth / 2;
      const min = cardHalf;
      const max = stageRect.width - cardHalf;
      const clamped = Math.max(min, Math.min(center, max));

      section.style.setProperty('--active-x', clamped + 'px');
    }

    function setActiveStep(index) {
      const item = steps[index];
      if (!item) return;

      stepButtons.forEach(function (button, buttonIndex) {
        const isActive = buttonIndex === index;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', String(isActive));
      });

      card.classList.add('is-changing');
      updateCardPosition(index);

      window.setTimeout(function () {
        cardImage.src = item.image;
        cardImage.alt = item.title;
        cardTitle.innerHTML = '<span>' + item.title + '</span> <em>' + item.english + '</em>';
        cardText.textContent = item.text;
        card.classList.remove('is-changing');
      }, 120);
    }

    stepButtons.forEach(function (button, index) {
      button.addEventListener('click', function () {
        setActiveStep(index);
      });
    });

    window.addEventListener('resize', function () {
      const activeIndex = stepButtons.findIndex(function (button) {
        return button.classList.contains('is-active');
      });

      updateCardPosition(Math.max(activeIndex, 0));
    });

    setActiveStep(0);
  });
</script>
